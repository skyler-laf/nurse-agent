{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/dist"
      }
    }
  ],
  "routes": [
    {
      "source": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "source": "/(.*)",
      "dest": "/$1"
    }
  ]
}
